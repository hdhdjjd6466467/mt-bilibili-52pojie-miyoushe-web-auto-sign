#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PID_FILE="$ROOT/state/web.pid"
LOG_FILE="$ROOT/logs/web.log"

mkdir -p "$ROOT/state" "$ROOT/logs"

if [[ -f "$PID_FILE" ]]; then
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
    echo "auto-sign web already running pid=$pid"
    exit 0
  fi
  rm -f "$PID_FILE"
fi

setsid "$ROOT/bin/web" </dev/null >> "$LOG_FILE" 2>&1 &
pid=$!
echo "$pid" > "$PID_FILE"
sleep 1

if kill -0 "$pid" 2>/dev/null; then
  echo "auto-sign web started pid=$pid"
  exit 0
fi

echo "auto-sign web failed to start" >&2
exit 1

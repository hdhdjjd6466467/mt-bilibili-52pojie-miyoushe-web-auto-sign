#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PID_FILE="$ROOT/state/web.pid"

if [[ ! -f "$PID_FILE" ]]; then
  echo "stopped"
  exit 1
fi

pid="$(cat "$PID_FILE" 2>/dev/null || true)"
if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
  echo "running pid=$pid"
  exit 0
fi

echo "stale pid file"
exit 1

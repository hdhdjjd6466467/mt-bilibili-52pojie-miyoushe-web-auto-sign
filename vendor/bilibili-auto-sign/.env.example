# 完整浏览器 Cookie，建议直接从 https://www.bilibili.com 导出整串
BILIBILI_COOKIE=

# 可选：自定义 UA
BILIBILI_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36

# 主站每日任务
BILIBILI_ENABLE_WATCH=true
BILIBILI_ENABLE_SHARE=true
BILIBILI_ENABLE_COIN=true

# 每天目标投币数，默认 5 枚可拿满 50 经验
BILIBILI_TARGET_DAILY_COINS=5

# 至少保留多少硬币不动
BILIBILI_PROTECTED_COINS=5

# 投币时是否顺手点赞
BILIBILI_LIKE_ON_COIN=true
